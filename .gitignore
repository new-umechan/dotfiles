# 最初にすべての階層のファイルを無視します
# 階層は必要なだけ追加する
### all ignore ###
/*
/.**

# .gitignoreは上から解釈されていくので
# 管理対象のファイルをホワイトリストのように追記します
### not ignore ###
!/.bin
!/.bin/**
!/.config
!/.config/**

!/.zshrc
!/.zsh/
!/.zsh/**

!/Vimium\ Options.json

!/README.md
!/LICENSE
!.gitignore

/.config/raycast/extensions/

/.config/karabiner/automatic_backups
/.config/opencode/opencode.json
/.config/mole/*

/.config/configstore/

.DS_Store
**/.qwen/
